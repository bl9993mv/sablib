-- =====================================================
-- SPOOF FUNCTION
-- =====================================================

local patchCount = 0
local hasExecuted = false

local function changeText(v)
    if v:IsA("TextLabel") and v.Text == "Secret" then
        v.Text = "OG"
        v.TextColor3 = Color3.fromRGB(255, 221, 85)
        if not v:FindFirstChildOfClass("UIStroke") then
            local stroke = Instance.new("UIStroke")
            stroke.Color = Color3.fromRGB(0, 0, 0)
            stroke.Thickness = 2
            stroke.Parent = v
        end
        patchCount += 1
    end
end

ActionButton.MouseButton1Click:Connect(function()
    if hasExecuted then return end
    hasExecuted = true
    ActionButton.Text = "APPLIED"
    ActionButton.BackgroundColor3 = Color3.fromRGB(85, 221, 136)
    ActionButton.Active = false
    for _, v in pairs(game:GetDescendants()) do
        changeText(v)
    end
    game.DescendantAdded:Connect(function(v)
        changeText(v)
    end)
end)

-- RAINBOW WATERMARK
local ytLabel = "bloomscripts on youtube"
local ytChars = {}

local ytContainer = Instance.new("Frame")
ytContainer.Size = UDim2.new(0, 126, 0, 14)
ytContainer.Position = UDim2.new(0.5, -63, 1, -22)
ytContainer.BackgroundTransparency = 1
ytContainer.ZIndex = 3
ytContainer.Parent = MainFrame

local layout = Instance.new("UIListLayout")
layout.FillDirection = Enum.FillDirection.Horizontal
layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
layout.SortOrder = Enum.SortOrder.LayoutOrder
layout.Padding = UDim.new(0, 0)
layout.Parent = ytContainer

for i = 1, #ytLabel do
    local char = Instance.new("TextLabel")
    char.Text = ytLabel:sub(i, i)
    char.Font = Enum.Font.GothamBold
    char.TextSize = 10
    char.BackgroundTransparency = 1
    char.Size = UDim2.new(0, ytLabel:sub(i, i) == " " and 3 or 6, 1, 0)
    char.ZIndex = 3
    char.LayoutOrder = i
    char.TextColor3 = Color3.fromRGB(255, 80, 80)
    char.Parent = ytContainer
    table.insert(ytChars, char)
end

local ytHue = 0
RunService.Heartbeat:Connect(function(dt)
    ytHue = (ytHue + dt * 0.4) % 1
    for i, char in ipairs(ytChars) do
        local offset = (i - 1) / #ytChars
        char.TextColor3 = Color3.fromHSV((ytHue + offset) % 1, 0.85, 1)
    end
end)

-- =====================================================
-- DRAG SYSTEM (MOBILE & PC)
-- =====================================================

local dragging = false
local dragInput = nil
local dragStart = nil
local startPos = nil

local function updateDrag(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
end

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

TitleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or
       input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input == dragInput then
        updateDrag(input)
    end
end)


-- Logic
local patchCount = 0
local hasExecuted = false

local function changeText(v)
    if v:IsA("TextLabel") and v.Text == "Secret" then
        v.Text = "OG"
        v.TextColor3 = Color3.fromRGB(255, 221, 85)
        if not v:FindFirstChildOfClass("UIStroke") then
            local stroke = Instance.new("UIStroke")
            stroke.Color = Color3.fromRGB(0, 0, 0)
            stroke.Thickness = 2
            stroke.Parent = v
        end
        patchCount += 1
        countLabel.Text = "Patched: " .. patchCount
    end
end

execBtn.MouseButton1Click:Connect(function()
    if hasExecuted then return end
    hasExecuted = true

    execBtn.Text = "APPLIED"
    execBtn.BackgroundColor3 = Color3.fromRGB(85, 221, 136)
    execBtn.Active = false
    statusLabel.Text = "Active"

    for _, v in pairs(game:GetDescendants()) do
        changeText(v)
    end

    game.DescendantAdded:Connect(function(v)
        changeText(v)
    end)
end)
